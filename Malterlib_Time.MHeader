Import "../Core/Lib_Malterlib.MTarget"

%Group "{Malterlib}/{Lib_Malterlib_Time}"
{
	%Group "Time"
	{
		%Group "Include"
		{
			Compile.Type "C++"
			{
				!!DocumentationEnabled true
			}
			%File "Include/Mib/Time/^*"
		}
		%File "Source/*"
		%Group "Platform"
		{
			%File "Source/Platform/*"
			{
				Compile.Disabled true
				{
					!PlatformFamily PlatformFamilyFromFile
				}
			}
		}
		%Group "Documentation"
		{
			%File "Documentation/*"
		}
	}
	%Dependency "Lib_Malterlib_Numeric"
	{
		!!MalterlibSubLibrarySeparate true
		Dependency.Indirect true
	}
}


Property
{
	MalterlibLibrary_Time: bool = MalterlibLibrary_All
	MalterlibSubLibraries =+ "Time"
	{
		!!MalterlibLibrary_Time true
	}
//	MalterlibSubLibrarySeparate_Lib_Malterlib_Time: bool = true
	MalterlibIncludeRoots =+ "Include"->MakeAbsolute()
	{
		!!MalterlibLibrary_Time true
	}
}

Property
{
	!!MalterlibEnableInternalTests true
	
	MalterlibTests =+ "Malterlib_Time"
	MalterlibTestFiles_Malterlib_Time: [type(CEntity)] = ["Test/*"->MakeAbsolute()]
}

